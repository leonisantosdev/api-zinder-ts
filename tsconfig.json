{
  "compilerOptions": {
    "target": "ES2017",                    // Define o alvo como ES2017 (ou superior)
    "module": "NodeNext",                    // Para usar módulos ES
    "moduleResolution": "nodenext",            // Resolução de módulos no estilo Node.js
    "outDir": "./dist",                    // Diretório de saída
    "rootDir": "./src",                    // Diretório de origem dos arquivos .ts
    "esModuleInterop": true,               // Compatibilidade para importação de módulos
    "allowSyntheticDefaultImports": true,  // Permite importações de módulos padrão
    "skipLibCheck": true,                  // Ignora a verificação de bibliotecas
    "strict": true,                        // Habilita verificações rigorosas de tipos
    "baseUrl": ".",                        // Base para resolver caminhos relativos
    "paths": {
      "*": ["node_modules/*", "src/*"]     // Ajusta os caminhos para src e node_modules
    }
  },
  "include": ["src/**/*"],  // Certifica-se de que todos os arquivos .ts da pasta src sejam incluídos na compilação
  "exclude": ["node_modules"]  // Exclui node_modules da compilação
}
