{
  "compilerOptions": {
    // "target": "ES6",
    "lib": ["ESNext"],                                        
    "experimentalDecorators": true,                
    "emitDecoratorMetadata": true,              
    // "module": "NodeNext",                               
    "rootDir": "./src",                                
    // "moduleResolution": "nodenext",               
    // "resolveJsonModule": true,                     
    "outDir": "./dist",                                  
    "esModuleInterop": true,                            
    "forceConsistentCasingInFileNames": true,         
    "strict": true,                                      
    "skipLibCheck": true                                 
  },
  "include": ["./src"],
  "exclude": ["node_modules"]
}
